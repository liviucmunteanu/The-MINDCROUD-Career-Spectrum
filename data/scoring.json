  "validity": {
    "attentionChecks": [
      { "q": 17, "correctResponse": 4 },
      { "q": 33, "correctResponse": 1 },
      { "q": 49, "correctResponse": 3 }
    ],
    "attentionRule": { "0": "pass", "1": "caution", "2+": "potentially-invalid" },
    "consistencyPairs": [
      { "pair": "A", "items": [1, 41] },
      { "pair": "B", "items": [10, 56] }
    ],
    "consistencyRule": {
      "consistent": "absolute difference 0-1 on a pair",
      "mild": "absolute difference 2 on a pair",
      "strong": "absolute difference 3-4 on a pair",
      "invalidIf": "any pair difference >= 3, OR both pairs difference >= 2"
    },
    "recommendedAutomatedScreens": {
      "minCompletionSeconds": 180,
      "longStringFlag": 12
    },
    "verdicts": {
      "valid": "no flags",
      "interpretWithCaution": "exactly one caution-level signal",
      "potentiallyInvalid": "any invalid-level signal, or two or more caution-level signals"
    }
  },
